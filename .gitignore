# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude local settings
.claude/

# raw AI-generated video originals (clean-named copies are committed instead)
public/videos/Cinematic_*
public/videos/*_202607110017.mp4

# oversized logo original (resized logo-brand-512/og are committed)
public/images/logo-brand.PNG

# raw seedream originals (clean teak-product/white-teak-product copies are committed)
public/images/seedream-*
